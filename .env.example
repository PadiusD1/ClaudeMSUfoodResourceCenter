# ─── Morgan Pantry Store – Environment Variables ─────────────────────────────
#
# Copy this file to .env and fill in the values you need.
# Only the API keys you provide will be used; missing keys are silently skipped.
#
# The barcode lookup endpoint queries all enabled APIs in parallel and returns
# the best match by confidence score. Open Food Facts, UPC Item DB, and USDA
# FoodData Central work without keys.

# ─── UPC Item DB (optional, improves results) ────────────────────────────────
# Free trial works without a key. For higher rate limits, sign up at:
# https://www.upcitemdb.com/wp/docs/main/development/getting-started/
UPCITEMDB_API_KEY=

# ─── Nutritionix (optional, great for nutrition data) ────────────────────────
# Sign up at: https://developer.nutritionix.com/
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=

# ─── USDA FoodData Central (optional, uses DEMO_KEY if not set) ──────────────
# Sign up at: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
