[Unit]
Description=Morgan Pantry Store
After=network.target

[Service]
Type=simple
User=pantry
WorkingDirectory=/opt/morgan-pantry
ExecStart=/usr/bin/node dist/index.cjs
Environment=NODE_ENV=production
Environment=PORT=5000
Restart=always
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=morgan-pantry

[Install]
WantedBy=multi-user.target
